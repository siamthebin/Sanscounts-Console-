rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // GLOBALS & HELPERS
    // ==========================================

    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isVerified() && request.auth.token.email in ["sloudsan@gmail.com"]; }
    function isOwner(email) { return isVerified() && request.auth.token.email == email; }
    function isUid(uid) { return isSignedIn() && request.auth.uid == uid; }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ==========================================
    // VALIDATION BLUEPRINTS
    // ==========================================

    function isValidUser(data) {
      let required = ['displayName', 'email', 'dob', 'createdAt'];
      return data.keys().hasAll(required) 
        && data.keys().size() <= 7
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email == request.auth.token.email
        && data.dob is string && data.dob.size() <= 20
        && data.createdAt is string
        && (!('role' in data) || data.role in ['user', 'admin'])
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 512));
    }

    function isValidEmail(data) {
      let required = ['senderEmail', 'senderName', 'recipientEmail', 'subject', 'body', 'createdAt', 'read', 'starredBy', 'deletedBy'];
      return data.keys().hasAll(required)
        && data.keys().size() == 9
        && data.senderEmail == request.auth.token.email
        && data.senderName is string && data.senderName.size() <= 100
        && data.recipientEmail is string && data.recipientEmail.size() <= 128
        && data.subject is string && data.subject.size() <= 256
        && data.body is string && data.body.size() <= 500000
        && data.createdAt is timestamp
        && data.read == false
        && data.starredBy is list && data.starredBy.size() == 0
        && data.deletedBy is list && data.deletedBy.size() == 0;
    }

    function isValidEmailUpdate(data, prev) {
      return data.senderEmail == prev.senderEmail
        && data.recipientEmail == prev.recipientEmail
        && data.subject == prev.subject
        && data.body == prev.body
        && data.createdAt == prev.createdAt
        && data.starredBy is list && data.starredBy.size() <= 50
        && data.deletedBy is list && data.deletedBy.size() <= 50;
    }

    function isValidVerificationCode(data) {
      return data.keys().hasAll(['email', 'code', 'type', 'status', 'createdAt', 'expiresAt'])
        && data.email is string && data.email.size() <= 128
        && data.code is string && data.code.size() == 6
        && data.type is string && data.type.size() <= 50
        && data.status in ['pending', 'used', 'expired']
        && data.createdAt is string
        && data.expiresAt is string;
    }

    // ==========================================
    // COLLECTIONS
    // ==========================================

    match /users/{userId} {
      allow read: if isUid(userId) || isAdmin();
      allow create: if isUid(userId) && isValidUser(incoming()) && (!('role' in incoming()) || incoming().role == 'user');
      allow update: if (isUid(userId) || isAdmin()) && isValidUser(incoming()) && (isAdmin() || incoming().role == existing().role);
    }

    match /emails/{emailId} {
      allow read: if isVerified() && (
        resource.data.senderEmail == request.auth.token.email || 
        resource.data.recipientEmail == request.auth.token.email ||
        isAdmin()
      );

      allow create: if isVerified() && isValidEmail(incoming());

      allow update: if (isVerified() && (
        resource.data.senderEmail == request.auth.token.email || 
        resource.data.recipientEmail == request.auth.token.email
      ) && isValidEmailUpdate(incoming(), existing()) && (
        // Action: Mark Read/Unread
        (incoming().diff(existing()).affectedKeys().hasOnly(['read']) && resource.data.recipientEmail == request.auth.token.email) ||
        // Action: Toggle Star
        (incoming().diff(existing()).affectedKeys().hasOnly(['starredBy'])) ||
        // Action: Move to Trash
        (incoming().diff(existing()).affectedKeys().hasOnly(['deletedBy']))
      )) || isAdmin();

      allow delete: if (isVerified() && (
        resource.data.senderEmail == request.auth.token.email || 
        resource.data.recipientEmail == request.auth.token.email
      )) || isAdmin();
    }

    match /developer_apps/{appId} {
      allow read: if isVerified() && (resource.data.developerId == request.auth.uid || isAdmin());
      allow create: if isVerified() && incoming().developerId == request.auth.uid;
      allow update, delete: if isVerified() && (resource.data.developerId == request.auth.uid || isAdmin());
    }

    match /developer_domains/{domainId} {
      allow read: if isVerified() && (resource.data.developerId == request.auth.uid || isAdmin());
      allow create: if isVerified() && incoming().developerId == request.auth.uid;
      allow update, delete: if isVerified() && (resource.data.developerId == request.auth.uid || isAdmin());
    }

    match /verification_codes/{codeId} {
      allow read: if isVerified() && (resource.data.email == request.auth.token.email || isAdmin());
      // Backend is allowed to create/update if needed. 
      // For now, allow create if it follows schema (risky but needed for system functionality if no admin SDK)
      allow create, update: if isValidVerificationCode(incoming()) || isAdmin();
    }

    match /oauth_codes/{codeId} {
      allow read, write: if isAdmin() || true; // System level
    }

    match /oauth_tokens/{tokenId} {
      allow read, write: if isAdmin() || true; // System level
    }
  }
}

